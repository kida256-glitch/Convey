# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# ─── Supabase (REQUIRED for cross-device / cross-wallet listing visibility) ────
#
# Without these the app falls back to a local file-based server.
# That only works on the same machine — listings won't appear on other devices.
#
# Free setup:
#   1. Create a project at https://supabase.com
#   2. In the SQL Editor run:
#
#      create table public.listings (
#        id          bigint generated always as identity primary key,
#        title       text    not null,
#        description text    not null default '',
#        seller      text    not null,
#        price       numeric not null,
#        stock       integer not null default 1,
#        status      text    not null default 'Active',
#        images      text[]  not null default '{}'
#      );
#      alter table public.listings enable row level security;
#      create policy "public read"   on public.listings for select using (true);
#      create policy "public insert" on public.listings for insert with check (true);
#      create policy "public update" on public.listings for update using (true);
#      create policy "public delete" on public.listings for delete using (true);
#
#   3. Copy your Project URL and anon key from: Settings → API
#   4. Paste them here (also add to your .env file).
#
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key-here"

# ─── Target chain ──────────────────────────────────────────────────────────────
# "fuji" = testnet  |  "avalanche" = mainnet  (default: fuji)
VITE_TARGET_CHAIN="fuji"

# ─── Contract address ──────────────────────────────────────────────────────────
VITE_CONTRACT_ADDRESS="0x0000000000000000000000000000000000000000"
