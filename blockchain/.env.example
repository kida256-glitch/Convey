# ── Deployer ─────────────────────────────────────────────────────────────────
# Private key of the wallet that will sign the deployment transaction.
# NEVER commit this file. Add it to .gitignore.
# Get test AVAX from https://core.app/tools/testnet-faucet/?subnet=c&token=c
DEPLOYER_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# ── Snowtrace (optional) ──────────────────────────────────────────────────────
# Required only if you want to verify the contract source on Snowtrace.
# Get a free key at https://snowtrace.io/myapikey
SNOWTRACE_API_KEY=YOUR_SNOWTRACE_API_KEY
